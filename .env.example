# =============================================================
# Aleph Dashboard V2 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# --- REQUIRED ---
# Brave Search API — https://brave.com/search/api/ (free tier: 2000 req/month)
BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# --- Server ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# --- CORS ---
# Comma-separated allowed origins. Leave empty to disable CORS (same-origin only).
# Use "*" to allow all origins (not recommended for production).
# Example: https://dashboard.aleph.im,https://admin.aleph.im
CORS_ALLOWED_ORIGINS=

# --- Auth ---
# Required for POST /api/run — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# --- Pipeline Intervals ---
STATUS_POLL_SECONDS=720
DISCOVERY_INTERVAL_MINUTES=45
SYNTHESIS_INTERVAL_MINUTES=60

# --- Brave Budget ---
BRAVE_MAX_MONTHLY_CALLS=2000
BRAVE_DEFAULT_COUNT=5
BRAVE_QUERY_LIMIT_PER_RUN=10

# --- Optional Overrides ---
# DB_PATH=data/aleph_v2.db
# MIN_SEVERITY=Medium
# DOCUMENT_BATCH_SIZE=40
# TREND_MAX_AGE_MINUTES=180
# SIGNALS_MAX_AGE_MINUTES=180
